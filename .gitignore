# Re-ignore local-only .claude paths (must come AFTER the !/.claude/ whitelist)
/.claude/settings.local.json
/.claude/worktrees/

# Autodev loop — ephemeral scratch only (blackboard + queue + escalations stay tracked)
/.autodev/runtime/
/.autodev/conductor.log

# OS / editor junk
.DS_Store
Thumbs.db
/.vscode/
