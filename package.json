{
  "name": "woodev_framework",
  "version": "1.0.0",
  "description": "Woodev Plugin Framework — build toolchain for the React-powered license management admin UI.",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "wp-scripts build ./src/license-page/index.js --output-path=woodev/assets/build/license-page",
    "start": "wp-scripts start ./src/license-page/index.js --output-path=woodev/assets/build/license-page"
  },
  "devDependencies": {
    "@wordpress/scripts": "32.4.0"
  }
}
