<?xml version="1.0"?>
<ruleset name="Woodev Plugin Framework">
	<description>PHP CodeSniffer rules for Woodev Plugin Framework</description>

	<!-- Какие файлы проверять -->
	<file>./woodev</file>

	<!-- Только PHP файлы -->
	<arg name="extensions" value="php"/>

	<!-- Красивый вывод с прогрессом -->
	<arg value="sp"/>
	<arg name="colors"/>
	<arg name="parallel" value="8"/>

	<!-- Исключаем vendor и node_modules -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>

	<!-- =====================================================
		 WordPress Coding Standards
	====================================================== -->

	<!-- WordPress standards -->
	<rule ref="WordPress-Core">
		<!-- Allow short array syntax [] instead of array() -->
		<exclude name="Generic.Arrays.DisallowShortArraySyntax.Found"/>
	</rule>
	<rule ref="WordPress-Extra">
		<!-- Allow test plugin file naming -->
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<!-- Allow mixed OO and functions for plugin bootstrap pattern -->
		<exclude name="Universal.Files.SeparateFunctionsFromOO.Mixed"/>
		<!-- Allow short array syntax [] instead of array() -->
		<exclude name="Generic.Arrays.DisallowShortArraySyntax.Found"/>
		<exclude name="Universal.Arrays.DisallowShortArraySyntax.Found"/>
	</rule>

	<!-- Стандарт документации (PHPDoc комментарии) -->
	<rule ref="WordPress-Docs"/>

	<!-- =====================================================
		 PHP Compatibility
		 Проверяем совместимость с PHP 7.4 и выше
	====================================================== -->
	<config name="testVersion" value="7.4-"/>
	<rule ref="PHPCompatibility"/>
	<rule ref="PHPCompatibilityWP"/>
	
	<!-- WordPress minimum version -->
	<config name="minimum_wp_version" value="5.9"/>

	<!-- =====================================================
		 Настройки специфичные для фреймворка
	====================================================== -->

	<!-- Префикс для функций и классов — замени на свой реальный префикс -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="woodev"/>
				<element value="Woodev"/>
			</property>
		</properties>
	</rule>

	<!-- Text domain фреймворка -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="woodev-plugin-framework"/>
			</property>
		</properties>
	</rule>

	<!-- Разрешаем длинные строки до 120 символов (WordPress по умолчанию 100) -->
	<rule ref="Generic.Files.LineLength">
		<properties>
			<property name="lineLimit" value="120"/>
			<property name="absoluteLineLimit" value="0"/>
		</properties>
	</rule>

</ruleset>