{
    "name": "woodev/plugin-framework",
    "description": "Woodev Plugin Framework — scaffold for developing WooCommerce plugins",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Woodev",
            "homepage": "https://github.com/kalbac/woodev-plugin-framework"
        }
    ],
    "require": {
        "php": ">=7.4 <9.0"
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "mockery/mockery": "^1.6",
        "php-stubs/woocommerce-stubs": "^10.5",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.9",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.1",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "classmap": [
            "woodev/admin",
            "woodev/api",
            "woodev/box-packer",
            "woodev/compatibility",
            "woodev/handlers",
            "woodev/licensing",
            "woodev/payment-gateway",
            "woodev/plugin-updater",
            "woodev/rest-api",
            "woodev/settings-api",
            "woodev/shipping-method",
            "woodev/utilities",
            "woodev/bootstrap.php",
            "woodev/class-plugin.php",
            "woodev/class-lifecycle.php",
            "woodev/class-helper.php",
            "woodev/class-admin-notice-handler.php",
            "woodev/class-admin-message-handler.php",
            "woodev/class-plugin-compatibility.php",
            "woodev/class-plugin-exception.php",
            "woodev/class-string-conversation.php",
            "woodev/class-woodev-hook-deprecator.php",
            "woodev/class-woodev-plugin-dependencies.php"
        ],
        "psr-4": {
            "Woodev\\Framework\\": "woodev/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Woodev\\Tests\\Unit\\": "tests/unit/",
            "Woodev\\Tests\\Integration\\": "tests/integration/"
        }
    },
    "scripts": {
        "phpcs":       "./vendor/bin/phpcs",
        "phpcbf":      "./vendor/bin/phpcbf",
        "phpstan":     "./vendor/bin/phpstan analyse --memory-limit=512M",
        "test":        "./vendor/bin/phpunit --testsuite=Unit",
        "test:unit":   "./vendor/bin/phpunit --testsuite=Unit",
        "test:integration": "./vendor/bin/phpunit --testsuite=Integration",
        "lint":        "@phpcs",
        "fix":         "@phpcbf",
        "check":       [
            "@phpcs",
            "@phpstan",
            "@test:unit"
        ]
    },
    "scripts-descriptions": {
        "phpcs":            "Run PHP CodeSniffer (check code style)",
        "phpcbf":           "Run PHP Code Beautifier (auto-fix code style)",
        "phpstan":          "Run PHPStan static analysis",
        "test":             "Run unit tests",
        "test:unit":        "Run unit tests only",
        "test:integration": "Run integration tests (requires wp-env)",
        "lint":             "Alias for phpcs",
        "fix":              "Alias for phpcbf",
        "check":            "Run all checks: phpcs + phpstan + unit tests"
    },
    "config": {
        "platform": {
            "php": "8.1"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
