# Normalize line endings for all text files
* text=auto

# PHP and config files — enforce LF
*.php text eol=lf
*.xml text eol=lf
*.neon text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.gif binary
*.zip binary
*.ico binary
