includes:
    # WordPress + WooCommerce stubs
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:

    # =================================================
    # Что анализируем
    # =================================================
    paths:
        - woodev

    # =================================================
    # WooCommerce stubs — загружаются как файлы с объявлениями
    # =================================================
    scanFiles:
        - vendor/php-stubs/woocommerce-stubs/woocommerce-stubs.php
        - vendor/php-stubs/woocommerce-stubs/woocommerce-packages-stubs.php

    # =================================================
    # Уровень строгости: 0 (минимум) — 9 (максимум)
    #
    # Стратегия: начинаем с уровня 3, постепенно
    # повышаем по мере исправления ошибок.
    #
    # Уровень 3 — хороший старт для легаси кода:
    # ловит реальные баги но не требует полной
    # аннотации типов везде.
    # =================================================
    level: 3

    # =================================================
    # PHP версия (соответствует composer.json)
    # =================================================
    phpVersion: 70400

    # =================================================
    # Исключения — что не анализируем
    # =================================================
    excludePaths:
        - woodev/assets
        - vendor

    # =================================================
    # Bootstrap файлы — загружаются перед анализом.
    # Здесь PHPStan узнаёт о легаси классах
    # которые не имеют неймспейсов.
    # =================================================
    bootstrapFiles:
        - woodev/bootstrap.php
        - woodev/class-plugin.php
        - woodev/class-helper.php
        - woodev/class-lifecycle.php
        - woodev/class-admin-notice-handler.php
        - woodev/class-admin-message-handler.php
        - woodev/compatibility/class-plugin-compatibility.php
        - woodev/class-plugin-exception.php
        - woodev/class-string-conversation.php
        - woodev/class-woodev-hook-deprecator.php
        - woodev/class-woodev-plugin-dependencies.php

    # =================================================
    # Параметры совместимые с легаси кодом
    # =================================================

    # Разрешает использование dynamic properties ($this->something
    # без объявления в классе) — нужно для легаси
    checkDynamicProperties: false

    # Не требует строгого return type везде — нужно для легаси
    treatPhpDocTypesAsCertain: false

    # Ограничиваем параллельные воркеры — WC stubs (130k строк) требует много памяти
    parallel:
        maximumNumberOfProcesses: 1

    # Не падать если ignoreErrors паттерн не совпал ни с одной ошибкой
    reportUnmatchedIgnoredErrors: false

    # =================================================
    # Игнорируемые ошибки
    #
    # По мере рефакторинга легаси кода — убирай
    # строки отсюда и повышай уровень анализа
    # =================================================
    ignoreErrors:
        # ---------------------------------------------------------------------------
        # WordPress/WooCommerce dynamic properties (legacy patterns)
        # ---------------------------------------------------------------------------

        # WC_Order/WC_Order_Refund — WooCommerce uses dynamic properties for meta fields
        # like billing_*, shipping_*, etc. via __get()/__set() magic methods.
        - '#Access to an undefined property WC_Order::\$#'
        - '#Cannot access property \$.* on WC_Order\|WC_Order_Refund\|false#'

        # WC_Session — uses dynamic properties for session data (legacy pattern)
        - '#Access to an undefined property WC_Session::\$#'

        # WP_User — get_user_by() may return false, billing_*/shipping_* are WC meta fields
        - '#Cannot access property \$.* on WP_User\|false#'

        # ---------------------------------------------------------------------------
        # WC core classes not present/complete in stubs
        # ---------------------------------------------------------------------------

        # WC Admin Navigation classes — removed in WC 9.x, kept for backward compat
        - '#Class Automattic\\WooCommerce\\Admin\\Features\\Navigation\\#'

        # WC HPOS internal classes — not present in woocommerce-stubs
        - '#Call to static method .* on an unknown class Automattic\\WooCommerce\\Internal\\DataStores\\Orders\\OrdersTableDataStore#'

        # ---------------------------------------------------------------------------
        # Cross-hierarchy method calls (parent sees child methods)
        # ---------------------------------------------------------------------------

        # Woodev_Plugin base class — get_gateways() exists in Woodev_Payment_Gateway_Plugin
        - '#Call to an undefined method Woodev_Plugin::get_gateways\(\)#'

        # Payment notification response — runtime implementations add methods
        - '#Call to an undefined method Woodev_Payment_Gateway_API_Payment_Notification_Response::#'

        # Payment token — runtime implementations add check_number, subscription methods
        - '#Call to an undefined method Woodev_Payment_Gateway_Payment_Token::get_check_number\(\)#'
        - '#Invalid array key type Woodev_Payment_Gateway_Payment_Token#'

        # Box packer item — get_product() added by runtime implementations
        - '#Call to an undefined method Woodev_Box_Packer_Item::get_product\(\)#'

        # Shipping API interface — Woodev_Shipping_*/Woodev_Exportable_* defined in plugins
        - message: '#(Woodev_Shipping|Woodev_Exportable|not subtype of Throwable)#'
          path: woodev/shipping-method/api/interface-shipping-api.php

        # ---------------------------------------------------------------------------
        # Utilities — intentional runtime patterns
        # ---------------------------------------------------------------------------

        # Background job handler — update_job() may return false, $job checked logically
        - message: '#Cannot access property \$.* on object\|false#'
          path: woodev/utilities/class-woodev-background-job-handler.php

        # Background job handler — delete_job() success path has no explicit return (by design)
        - message: '#Method .* should return false but return statement is missing#'
          path: woodev/utilities/class-woodev-background-job-handler.php

        # plugin-updater — convert_object_to_array() iterates stdClass via foreach (valid PHP)
        - message: '#Argument of an invalid type stdClass supplied for foreach#'
          path: woodev/plugin-updater/class-plugin-updater.php

        # class-string-conversation.php — static analysis limited when unset on fixed arrays
        - message: '#Cannot unset offset .* on array#'
          path: woodev/class-string-conversation.php

        # ---------------------------------------------------------------------------
        # WordPress action hook pattern — callbacks may return values
        # (methods serve dual purpose: direct calls + hook callbacks)
        # ---------------------------------------------------------------------------
        - '#Action callback returns .* but should not return anything#'
